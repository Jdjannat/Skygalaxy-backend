API_PORT=5000
CORS_ORIGIN=http://localhost:4200,https://skygalaxyinfotech.com
AUTH_TOKEN=skygalaxy_infotech_admin_token
DATA_DIR=./data

# Gmail SMTP setup
SMTP_SERVICE=gmail
SMTP_USER=skygalaxyinfotech@gmail.com
SMTP_PASS=your_gmail_app_password

# Sender and admin recipient
MAIL_FROM=skygalaxyinfotech@gmail.com
MAIL_TO=skygalaxyinfotech@gmail.com

# Optional attachment size limit for contact form (in MB)
MAX_ATTACHMENT_SIZE_MB=8

# If true, /api/contact waits for SMTP before responding (slower).
# Keep false for fast API response and background email sending.
CONTACT_EMAIL_SYNC=false

# Timeout for receiving contact multipart request body (milliseconds)
CONTACT_REQUEST_TIMEOUT_MS=20000
